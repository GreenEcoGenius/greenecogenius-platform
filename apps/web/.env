# SHARED ENVIRONMENT VARIABLES

# SITE
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=GreenEcoGenius
NEXT_PUBLIC_SITE_TITLE="GreenEcoGenius — Building Today To Preserve Tomorrow"
NEXT_PUBLIC_SITE_DESCRIPTION="GreenEcoGenius is a B2B circular economy platform that transforms industrial waste into growth opportunities through marketplace, blockchain traceability, and AI-powered CSR tools."
NEXT_PUBLIC_DEFAULT_THEME_MODE=light
NEXT_PUBLIC_THEME_COLOR="#00B67A"
NEXT_PUBLIC_THEME_COLOR_DARK="#1B2A3D"

# AUTH
NEXT_PUBLIC_AUTH_PASSWORD=true
NEXT_PUBLIC_AUTH_MAGIC_LINK=false
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# BILLING
NEXT_PUBLIC_BILLING_PROVIDER=stripe

# CMS
CMS_CLIENT=keystatic

# KEYSTATIC
NEXT_PUBLIC_KEYSTATIC_CONTENT_PATH=./content

# LOCALES PATH
NEXT_PUBLIC_LOCALES_PATH=apps/web/public/locales

# FEATURE FLAGS
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true
NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_DELETION=true
NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_BILLING=true
NEXT_PUBLIENABLE_TEAM_ACCOUNTS_DELETION=true
NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_BILLING=true
NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS=true
NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_CREATION=true
NEXT_PUBLIC_ENABLE_TEAMS_ACCOUNTS_ONLY=false
NEXT_PUBLIC_LANGUAGE_PRIORITY=application

# NEXTJS
NEXT_TELEMETRY_DISABLED=1
